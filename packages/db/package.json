{
  "name": "@hackjudge/db",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsup src/index.ts --format cjs,esm --dts",
    "dev": "prisma generate && tsup src/index.ts --format cjs,esm --dts --watch",
    "seed": "tsx prisma/seed.ts",
    "generate": "prisma generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "prisma": "^5.14.0",
    "tsup": "^8.0.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0"
  }
}
