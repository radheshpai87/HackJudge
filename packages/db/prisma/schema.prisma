// MongoDB Atlas Schema for HackJudge
// DATABASE_URL format: mongodb+srv://username:password@cluster.mongodb.net/hackjudge?retryWrites=true&w=majority

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  name          String
  image         String?
  googleId      String?   @unique @map("google_id")
  passwordHash  String?   @map("password_hash")
  role          String    @default("organizer")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  events Event[]

  @@map("users")
}

model Event {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?  @map("user_id") @db.ObjectId
  slug       String   @unique
  configJson Json     @map("config_json")
  configHash String   @map("config_hash")
  status     String   @default("draft")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user             User?            @relation(fields: [userId], references: [id])
  tracks           Track[]
  criteria         Criterion[]
  teams            Team[]
  judges           Judge[]
  assignments      Assignment[]
  scores           Score[]
  scoreSubmissions ScoreSubmission[]
  auditLogs        AuditLog[]
  resultSnapshots  ResultSnapshot[]

  @@index([status])
  @@index([userId])
  @@map("events")
}

model Track {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String  @map("event_id") @db.ObjectId
  name        String
  description String?

  event       Event        @relation(fields: [eventId], references: [id])
  criteria    Criterion[]
  teams       Team[]
  judgeTracks JudgeTrack[]

  @@index([eventId])
  @@map("tracks")
}

model Criterion {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String  @map("event_id") @db.ObjectId
  trackId     String? @map("track_id") @db.ObjectId
  name        String
  weight      Float
  maxScore    Int     @map("max_score")
  scoringType String  @default("numeric") @map("scoring_type")
  rubric      Json?

  event  Event   @relation(fields: [eventId], references: [id])
  track  Track?  @relation(fields: [trackId], references: [id])
  scores Score[]

  @@index([eventId])
  @@index([trackId])
  @@map("criteria")
}

model Team {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String   @map("event_id") @db.ObjectId
  name        String
  trackId     String?  @map("track_id") @db.ObjectId
  tableNumber String?  @map("table_number")
  members     String[] @default([])

  event            Event             @relation(fields: [eventId], references: [id])
  track            Track?            @relation(fields: [trackId], references: [id])
  assignments      Assignment[]
  scores           Score[]
  scoreSubmissions ScoreSubmission[]

  @@index([eventId])
  @@index([trackId])
  @@map("teams")
}

model Judge {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  eventId      String    @map("event_id") @db.ObjectId
  name         String
  email        String
  passwordHash String?   @map("password_hash")
  lastLoginAt  DateTime? @map("last_login_at")

  event            Event             @relation(fields: [eventId], references: [id])
  judgeTracks      JudgeTrack[]
  assignments      Assignment[]
  scores           Score[]
  scoreSubmissions ScoreSubmission[]

  @@unique([eventId, email])
  @@index([eventId])
  @@map("judges")
}

model JudgeTrack {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  judgeId String @map("judge_id") @db.ObjectId
  trackId String @map("track_id") @db.ObjectId

  judge Judge @relation(fields: [judgeId], references: [id])
  track Track @relation(fields: [trackId], references: [id])

  @@unique([judgeId, trackId])
  @@map("judge_tracks")
}

model Assignment {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  judgeId String @map("judge_id") @db.ObjectId
  teamId  String @map("team_id") @db.ObjectId
  eventId String @map("event_id") @db.ObjectId

  judge Judge @relation(fields: [judgeId], references: [id])
  team  Team  @relation(fields: [teamId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([judgeId, teamId])
  @@index([eventId])
  @@index([judgeId])
  @@map("assignments")
}

model Score {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String   @map("event_id") @db.ObjectId
  judgeId     String   @map("judge_id") @db.ObjectId
  teamId      String   @map("team_id") @db.ObjectId
  criterionId String   @map("criterion_id") @db.ObjectId
  value       Float
  submittedAt DateTime @default(now()) @map("submitted_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event     Event     @relation(fields: [eventId], references: [id])
  judge     Judge     @relation(fields: [judgeId], references: [id])
  team      Team      @relation(fields: [teamId], references: [id])
  criterion Criterion @relation(fields: [criterionId], references: [id])

  @@unique([judgeId, teamId, criterionId])
  @@index([eventId])
  @@index([teamId])
  @@index([judgeId])
  @@map("scores")
}

model ScoreSubmission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  judgeId     String   @map("judge_id") @db.ObjectId
  teamId      String   @map("team_id") @db.ObjectId
  eventId     String   @map("event_id") @db.ObjectId
  completedAt DateTime @default(now()) @map("completed_at")
  notes       String?

  judge Judge @relation(fields: [judgeId], references: [id])
  team  Team  @relation(fields: [teamId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([judgeId, teamId])
  @@index([eventId])
  @@index([judgeId])
  @@map("score_submissions")
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @map("event_id") @db.ObjectId
  actorId   String   @map("actor_id")
  actorType String   @map("actor_type")
  action    String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ResultSnapshot {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String   @map("event_id") @db.ObjectId
  generatedAt DateTime @default(now()) @map("generated_at")
  data        Json
  isPublished Boolean  @default(false) @map("is_published")

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([generatedAt])
  @@map("result_snapshots")
}
